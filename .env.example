# --- Database (Neon free tier) -------------------------------------------------
# Create a free project at https://neon.tech (no credit card) and paste its
# connection string. Use the POOLED connection string for deploys.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Mapbox --------------------------------------------------------------------
# Two tokens, BOTH public "pk." — same "Create a token" flow at
# console.mapbox.com/account/access-tokens (no geocoding scope exists; default
# public scopes cover tiles AND geocoding). Splitting them lets you lock down the
# browser token without breaking server-side geocoding.
#
# 1) BROWSER token — exposed to the client for map tiles. Create a NAMED token
#    and add URL restrictions (http://localhost:3000 + your domain). The account
#    default token can't be URL-restricted, so make a new one.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="pk.your_browser_token"
#
# 2) SERVER token — used only here for geocoding, never shipped to the browser.
#    Leave it WITHOUT URL restrictions: a URL-restricted token 403s on server
#    requests (no Referer header). If unset, the browser token above is used —
#    fine for localhost; do the split before you add URL restrictions / deploy.
# MAPBOX_TOKEN="pk.your_server_token"
#
# Storing coordinates requires Permanent Geocoding (set per-request in code as
# permanent=true). That's an ACCOUNT-level thing — just a credit card on file
# (~$5/1k, but we cache one geocode per place forever, so it's cents/year). Not a
# token scope. Set false only to test on an account with no card (results not
# stored, per Mapbox terms — throwaway dev data only):
# MAPBOX_PERMANENT="true"
#
# Force the free OpenStreetMap/Nominatim geocoder instead of Mapbox:
# GEOCODER="nominatim"

# --- Anthropic (optional) ------------------------------------------------------
# Without this, a built-in quick parser is used. With it, captures are parsed by
# Claude Haiku 4.5 (pennies — a single capture is a fraction of a cent).
ANTHROPIC_API_KEY="sk-ant-xxxxxxxx"
